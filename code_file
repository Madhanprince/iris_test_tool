// 🔹 Sensor Box
QLabel* createSensorBox(QString name)
{
    QLabel *label = new QLabel(name);
    label->setAlignment(Qt::AlignCenter);
    label->setFixedSize(80, 40);

    label->setStyleSheet(
        "background-color: red;"
        "color: white;"
        "border-radius: 10px;"
        "font-weight: bold;"
    );

    return label;
}

// 🔹 Page
QWidget* createPage(QString title)
{
    QWidget *page = new QWidget();
    QVBoxLayout *layout = new QVBoxLayout(page);

    layout->setSpacing(15);
    layout->setContentsMargins(15, 15, 15, 15);

    QLabel *label = new QLabel(title);
    label->setAlignment(Qt::AlignCenter);
    label->setStyleSheet("font-size: 20px;");

    layout->addWidget(label);
    return page;
}

int main(int argc, char *argv[])
{
    QApplication app(argc, argv);
    QMainWindow window;

    QWidget *central = new QWidget();
    QVBoxLayout *mainLayout = new QVBoxLayout(central);

    // 🔥 Global spacing
    mainLayout->setSpacing(10);
    mainLayout->setContentsMargins(10, 10, 10, 10);

    // 🔝 HEADER
    QHBoxLayout *headerLayout = new QHBoxLayout();
    headerLayout->setSpacing(10);

    headerLayout->addWidget(createSensorBox("CAM1"));
    headerLayout->addWidget(createSensorBox("CAM2"));
    headerLayout->addWidget(createSensorBox("CAM3"));
    headerLayout->addWidget(createSensorBox("CAM4"));
    headerLayout->addSpacing(20);
    headerLayout->addWidget(createSensorBox("LIDAR"));
    headerLayout->addSpacing(20);
    headerLayout->addWidget(createSensorBox("US1"));
    headerLayout->addWidget(createSensorBox("US2"));
    headerLayout->addWidget(createSensorBox("US3"));

    mainLayout->addLayout(headerLayout);

    // 🔻 BODY
    QHBoxLayout *bodyLayout = new QHBoxLayout();
    bodyLayout->setSpacing(10);

    // 🔹 Sidebar
    QListWidget *sidebar = new QListWidget();

    sidebar->setStyleSheet(R"(
        QListWidget {
            background-color: #f2f2f2;
            border: none;
            font-size: 14px;
        }

        QListWidget::item {
            padding: 12px;
            margin-left: 10px;
        }

        QListWidget::item:selected {
            background-color: #d6e4ff;
            border-radius: 8px;
        }

        QListWidget::item:hover {
            background-color: #e6e6e6;
            border-radius: 8px;
        }
    )");

    // 🔹 ESS Title
    QListWidgetItem *title = new QListWidgetItem("   ESS");
    title->setFlags(Qt::NoItemFlags);
    title->setSizeHint(QSize(150, 40));
    sidebar->addItem(title);
  
    // 🔥 Added items
    sidebar->addItem("  Logs");
    sidebar->addItem("  Mapping");

    sidebar->setFixedWidth(260);

    // 🔹 Pages
    QStackedWidget *pages = new QStackedWidget();
    pages->setStyleSheet("background-color: white;");

    // 🔥 Added pages
    pages->addWidget(createPage("Logs"));
    pages->addWidget(createPage("Mapping"));

    // 🔗 Sidebar → Pages
    QObject::connect(sidebar, &QListWidget::currentRowChanged,
                     [&](int row){
        if(row > 0)
            pages->setCurrentIndex(row - 1);
    });

    sidebar->setCurrentRow(1);

    // 🔻 Layout
    bodyLayout->addWidget(sidebar);
    bodyLayout->addWidget(pages);

    mainLayout->addLayout(bodyLayout);

    window.setCentralWidget(central);
    window.resize(1100, 650);
    window.setWindowTitle("Autonomous Cleaning Machine - Test UI");
    window.show();

    return app.exec();
}
